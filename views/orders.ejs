<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Orders</title>
    <link href="/style.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-3">
    <header class="header-box d-flex justify-content-between align-items-center">
        <a href="/user" class="logo d-flex align-items-center text-decoration-none">
            <span class="fs-4 fw-semibold text-dark">Cartify</span>
        </a>
        <ul class="nav nav-pills align-items-center">
            <li class="nav-item"><a href="/user" class="nav-link">Home</a></li>
            <li class="nav-item"><a href="/cart" class="nav-link">Cart</a></li>
            <li class="nav-item"><a href="/userproducts" class="nav-link">Products</a></li>
            <li class="nav-item"><a href="/orders" class="nav-link active">Orders</a></li>
            <li class="nav-item ms-3">
                <form action="/logout" method="POST">
                    <button type="submit" class="btn btn-outline-danger">Logout</button>
                </form>
            </li>
        </ul>
    </header>
</div>
<div class="container mt-5">
    <h2 class="mb-4">Your Orders</h2>
    <% if (orders.length === 0) { %>
        <div class="alert alert-info">
            You have not placed any orders yet.
        </div>
    <% } %>
    <% orders.forEach(function(order){ %>
        <div class="card mb-4 shadow-sm">
            <div class="card-header d-flex justify-content-between">
                <div>
                    <strong>Order Date:</strong>
                    <%= new Date(order.createdAt).toLocaleString() %>
                </div>
                <div>
                    <strong>Total:</strong>
                    ₹ <%= order.totalAmount %>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <% order.products.forEach(function(item){ %>
                        <div class="col-md-4 mb-3">
                            <div class="border rounded p-3 h-100">
                                <img 
                                    src="/uploads/<%= item.productId.image %>" 
                                    class="img-fluid mb-2"
                                    style="height:150px; object-fit:cover;"
                                >
                                <h6><%= item.productId.name %></h6>
                                <p class="mb-1">
                                    Price: ₹ <%= item.productId.price %>
                                </p>
                                <p class="mb-1">
                                    Quantity: <%= item.quantity %>
                                </p>
                                <p class="fw-bold">
                                    Subtotal: ₹ 
                                    <%= item.productId.price * item.quantity %>
                                </p>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    <% }) %>
</div>
</body>
</html>