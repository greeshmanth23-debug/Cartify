<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Cartify</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="user-body">

<div class="container mt-3">
    <header class="header-box d-flex justify-content-between align-items-center">

        <a href="/user" class="logo d-flex align-items-center text-decoration-none">
            <div class="d-flex align-items-center">
  <svg xmlns="http://www.w3.org/2000/svg"
       width="36"
       height="36"
       fill="currentColor"
       class="bi bi-bag-check me-2"
       viewBox="0 0 16 16">
    <path fill-rule="evenodd" d="M10.854 5.854a.5.5 0 0 0-.708-.708L7 8.293 5.854 7.146a.5.5 0 1 0-.708.708l1.5 1.5a.5.5 0 0 0 .708 0z"/>
    <path d="M8 1a2 2 0 0 0-2 2H4a1 1 0 0 0-1 1v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4a1 1 0 0 0-1-1h-2a2 2 0 0 0-2-2m1 2H7a1 1 0 0 1 2 0"/>
  </svg>

  <span class="fs-4 fw-semibold text-dark">Foodify</span>
</div>
        </a>

        <ul class="nav nav-pills align-items-center">
            <li class="nav-item">
                <a href="/user" class="nav-link active">Home</a>
            </li>
            <li class="nav-item">
                <a href="/cart" class="nav-link">Cart</a>
            </li>
            <li class="nav-item">
                <a href="/userproducts" class="nav-link">Products</a>
            </li>
            <li class="nav-item">
                <a href="/orders" class="nav-link">Orders</a>
            </li>
            <li class="nav-item ms-3">
                <form action="/logout" method="POST">
                    <button type="submit" class="btn btn-outline-danger">Logout</button>
                </form>
            </li>
        </ul>

    </header>
</div>

<div class="container-img mt-4">
    <div class="container-text">
        <h3>Feed your Cravings, without any efforts.</h3>
        <h5>From starters to desserts find it all on Foodify.</h5>
        <div class="badge bg-primary">
            <a href="/userproducts" style="color: rgb(7, 8, 8);text-decoration: none; font-size: 1.1rem;">Explore the dishes</a>
        </div>
    </div>
</div>
<div class="container-groceries product-sec">
    <h2>Starters</h2>
        <div class="products">
        <%  starters.forEach(function(starters){ %>
            <div class="product-card">
                <img src="/uploads/<%=starters.image%>" width="100%">
                <h3><%= starters.name %></h3>
                <div class="product-det">
                    <span class="badge bg-primary"><%= starters.category %></span>
                    <span class="badge bg-success"><%= starters.quantity %> in stock</span>
                </div>
                <div class="product-det">
                    <p class="badge bg-danger">Price: ₹<%= starters.price %></p>
                    <a class="know-more" href="/userproduct/<%= starters._id %>" style="text-decoration: none;">Know More</a>
                </div>
                <div class="addtocart">
                    <form action="/save-cart/<%=starters._id%>" method="POST">
                        <button type="submit" class="badge bg-primary" style="width: 100%;">Add to cart</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>
</div>
<div class="container-electronics product-sec mt-5">
    <h2>Main Courses</h2>
    <div class="products">
        <% maincourses.forEach(function(maincourse){ %>
            <div class="product-card">
                <img src="/uploads/<%= maincourse.image %>" width="100%">
                <h3><%= maincourse.name %></h3>
                <div class="product-det">
                    <span class="badge bg-primary"><%= maincourse.category %></span>
                    <span class="badge bg-success"><%= maincourse.quantity %> in stock</span>
                </div>
                <div class="product-det">
                    <p class="badge bg-danger">Price: ₹<%= maincourse.price %></p>
                    <a class="know-more" href="/userproduct/<%= maincourse._id %>" style="text-decoration: none;">Know More</a>
                </div>
                <div class="addtocart">
                    <form action="/save-cart/<%= maincourse._id %>" method="POST">
                        <button type="submit" class="badge bg-primary" style="width: 100%;">Add to cart</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>
</div>
<div class="container-decoratives product-sec mt-5">
    <h2>Desserts</h2>
    <div class="products">
        <% desserts.forEach(function(dessert){ %>
            <div class="product-card">
                <img src="/uploads/<%= dessert.image %>" width="100%">
                <h3><%= dessert.name %></h3>
                <div class="product-det">
                    <span class="badge bg-primary"><%= dessert.category %></span>
                    <span class="badge bg-success"><%= dessert.quantity %> in stock</span>
                </div>
                <div class="product-det">
                    <p class="badge bg-danger">Price: ₹<%= dessert.price %></p>
                    <a class="know-more" href="/userproduct/<%= dessert._id %>" style="text-decoration: none;">Know More</a>
                </div>
                <div class="addtocart">
                    <form action="/save-cart/<%= dessert._id %>" method="POST">
                        <button type="submit" class="badge bg-primary" style="width: 100%;">Add to cart</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>
</div>

</body>
</html>