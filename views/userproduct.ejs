<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
</head>
<body class="bg-light d-flex justify-content-center align-items-center" style="min-height:100vh;">

<div class="card shadow-sm border-0 p-4 text-center" style="max-width:500px; width:100%;">


    <div class="text-start mb-3">
        <a href="/userproducts" class="text-decoration-none fw-semibold text-dark">
            ← Back to Products
        </a>
    </div>
    <div class="mb-3">
        <img src="/uploads/<%= product.image %>" 
             class="img-fluid rounded"
             style="max-height:200px; object-fit:cover;">
    </div>


    <h4 class="fw-bold mb-2"><%= product.name %></h4>

    <p class="text-primary fw-semibold mb-2">
        ₹ <%= product.price %>
    </p>

    <p class="text-muted small mb-3">
        <%= product.discription %>
    </p>

    <div class="mb-3">
        <span class="badge bg-secondary me-2">
            <%= product.category %>
        </span>
        <span class="badge bg-success">
            <%= product.quantity %> in stock
        </span>
    </div>

    <div class="addtocart">
        <form action="/save-cart/<%=product._id%>" method="POST">
            <button type="submit" class="badge bg-primary" style="width: 150px;">Add to cart</button>
        </form>
    </div>
</div>

</body>
</html>