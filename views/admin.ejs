<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/style.css"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  </head>
  <body class="admin-body">
    <div class="container-fluid py-3">
        <div class="d-flex justify-content-end" style="padding-right: 150px;">
            <form action="/logout" method="POST">
                <button type="submit" class="btn btn-outline-danger">Logout</button>
            </form>
        </div>
    </div>
    <div class="form">
      <h2>ADD YOUR PRODUCTS</h2>
      <form class="row g-3" action="/save-product" method="POST" enctype="multipart/form-data">
        <div class="col-md-6">
          <label for="Name" class="form-label">Name</label>
          <input type="text" class="form-control" id="name" name="name" />
        </div>
        <div class="col-md-6">
          <label for="price" class="form-label">Price</label>
          <input type="number" class="form-control" id="price" name="price"/>
        </div>
        <div class="col-12">
          <label for="discription" class="form-label">Discription</label>
          <input
            type="text"
            class="form-control"
            id="discription"
            placeholder="About your product"
            name="discription"
          />
        </div>
        <div class="col-md-6">
          <label for="quantity" class="form-label">Quantity</label>
          <input type="number" class="form-control" id="quantity" name="quantity"/>
        </div>
        <div class="col-md-6">
          <label for="category" class="form-label">Category</label>
          <select id="category" class="form-select" name="category">
            <option value="electronics">Electronics</option>
            <option value="grocery" default>Grocery</option>
            <option value="decoratives">Decoratives</option>
          </select>
        </div>
        <div class="col-12">
          <label for="image" class="form-label">Image</label>
          <input type="file" class="form-control" name="image" id="image" />
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary">Add product</button>
        </div>
        
      </form>
    </div>
    <div class="product-sec">
        <h2>PRODUCTS</h2>
        <div class="products">
        <% products.forEach((product)=>{ %>
            <div class="product-card">
                <img src="/uploads/<%=product.image%>" width="100%">
                <h3><%= product.name %></h3>
                <div class="product-det">
                    <span class="badge bg-primary"><%= product.category %></span>
                    <span class="badge bg-success"><%= product.quantity %> in stock</span>
                </div>
                <div class="product-det">
                    <p class="badge bg-danger">Price: ₹<%= product.price %></p>
                    <a class="know-more" href="/product/<%= product._id %>">Know More</a>
                </div>
                <div class="product-fun">
                    <form action="/delete/<%=product._id%>" method="POST">
                        <button type="submit" class="delete"><img src="/images/delete.png"></button>
                    </form>
                    <button onclick="update('<%= product._id %>','<%= product.name %>','<%= product.price %>','<%= product.discription %>','<%= product.quantity %>','<%= product.category %>')" class="delete"><img src="/images/edit.jpg"></button>
                </div>
            </div>
        <% }) %>
        </div>
    </div>
    <hr class="mt-5">

<h2 class="text-center mt-4 mb-4">ORDERS RECEIVED</h2>

<% if (orders.length === 0) { %>
    <p class="text-center">No orders received yet.</p>
<% } %>

<% orders.forEach(order => { %>

<div class="card mb-4 p-3 shadow-sm">

    <h5>
        👤 User: <strong><%= order.username %></strong>
    </h5>

    <p>
        🕒 Ordered on:
        <%= new Date(order.createdAt).toLocaleString() %>
    </p>

    <ul class="list-group mb-3">
        <% order.products.forEach(item => { %>
            <li class="list-group-item d-flex justify-content-between">
                <span>
                    <%= item.productId ? item.productId.name : "Deleted Product" %>
                    (x <%= item.quantity %>)
                </span>
                <span>
                    ₹ <%= item.productId ? item.productId.price * item.quantity : 0 %>
                </span>
            </li>
        <% }) %>
    </ul>

    <h6 class="text-end">
        Total: ₹ <%= order.totalAmount %>
    </h6>

</div>

<% }) %>
    <script>
        function update(id,name,price,discription,quantity,image){
            document.getElementById('name').value=name;
            document.getElementById('price').value=price;
            document.getElementById('discription').value=discription;
            document.getElementById('quantity').value=quantity;

            fetch(`/delete/${id}`,{
                method:'POST'
            })
        }
    </script>
  </body>
</html>
