<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin</title>

    <link rel="stylesheet" href="/style.css"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        /* 🔥 ORDER GRID */
        .orders-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            width: 90%;
            margin: auto;
        }

        .order-card {
            background: #fff;
            padding: 18px;
            border-radius: 12px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
            transition: 0.3s ease;
        }

        .order-card:hover {
            transform: translateY(-5px);
        }

        .order-item {
            display: flex;
            justify-content: space-between;
            background: #f1f3f5;
            padding: 8px 10px;
            border-radius: 6px;
            margin-top: 8px;
        }

        .order-total {
            text-align: right;
            font-weight: bold;
            margin-top: 10px;
        }
    </style>
</head>

<body class="admin-body">

<!-- LOGOUT -->
<div class="container-fluid py-3">
    <div class="d-flex justify-content-end" style="padding-right: 150px;">
        <form action="/logout" method="POST">
            <button type="submit" class="btn btn-outline-danger">Logout</button>
        </form>
    </div>
</div>

<!-- ADD PRODUCT -->
<div class="form">
    <h2>ADD YOUR PRODUCTS</h2>

    <form class="row g-3" action="/save-product" method="POST" enctype="multipart/form-data">

        <div class="col-md-6">
            <label>Name</label>
            <input type="text" class="form-control" id="name" name="name">
        </div>

        <div class="col-md-6">
            <label>Price</label>
            <input type="number" class="form-control" id="price" name="price">
        </div>

        <div class="col-12">
            <label>Description</label>
            <input type="text" class="form-control" id="discription" name="discription">
        </div>

        <div class="col-md-6">
            <label>Quantity</label>
            <input type="number" class="form-control" id="quantity" name="quantity">
        </div>

        <div class="col-md-6">
            <label>Category</label>
            <select class="form-select" name="category">
                <option value="starters">Starters</option>
                <option value="maincourses">Main Courses</option>
                <option value="desserts">Desserts</option>
            </select>
        </div>

        <div class="col-12">
            <label>Image</label>
            <input type="file" class="form-control" name="image">
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Add Product</button>
        </div>

    </form>
</div>

<!-- PRODUCTS -->
<div class="product-sec">
    <h2>PRODUCTS</h2>

    <div class="products">
        <% products.forEach((product)=>{ %>

        <div class="product-card">
            <img src="/uploads/<%=product.image%>">

            <h3><%= product.name %></h3>

            <div class="product-det">
                <span class="badge bg-primary"><%= product.category %></span>
                <span class="badge bg-success"><%= product.quantity %> in stock</span>
            </div>

            <div class="product-det">
                <p class="badge bg-danger">₹ <%= product.price %></p>
                <a class="know-more" href="/product/<%= product._id %>">Know More</a>
            </div>

            <div class="product-fun">
                <form action="/delete/<%=product._id%>" method="POST">
                    <button type="submit">
                        <img src="/images/delete.png">
                    </button>
                </form>

                <button onclick="update('<%= product._id %>','<%= product.name %>','<%= product.price %>','<%= product.discription %>','<%= product.quantity %>')">
                    <img src="/images/edit.jpg">
                </button>
            </div>
        </div>

        <% }) %>
    </div>
</div>

<hr class="mt-5">

<!-- ORDERS -->
<h2 class="text-center mt-4 mb-4">ORDERS RECEIVED</h2>

<% if (orders.length === 0) { %>
    <p class="text-center">No orders received yet.</p>
<% } %>

<div class="orders-grid">

<% orders.forEach(order => { %>

    <div class="order-card">

        <h6>👤 User: <strong><%= order.username %></strong></h6>

        <p>🕒 <%= new Date(order.createdAt).toLocaleString() %></p>

        <% order.products.forEach(item => { %>

            <div class="order-item">
                <span>
                    <%= item.productId ? item.productId.name : "Deleted Product" %> 
                    (x <%= item.quantity %>)
                </span>

                <span>
                    ₹ <%= item.productId ? item.productId.price * item.quantity : 0 %>
                </span>
            </div>

        <% }) %>

        <div class="order-total">
            Total: ₹ <%= order.totalAmount %>
        </div>

    </div>

<% }) %>

</div>

<!-- SCRIPT -->
<script>
function update(id,name,price,discription,quantity){
    document.getElementById('name').value=name;
    document.getElementById('price').value=price;
    document.getElementById('discription').value=discription;
    document.getElementById('quantity').value=quantity;

    fetch(`/delete/${id}`,{
        method:'POST'
    })
}
</script>

</body>
</html>